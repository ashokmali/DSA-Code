from collections import deque

def bfs(n, edges, start):
    """
    n      : number of nodes (0 to n-1)
    edges  : list of (u, v)
    start  : starting node
    """

    # Step 1: Build adjacency list
    graph = [[] for _ in range(n)]
    for u, v in edges:
        graph[u].append(v)
        # If undirected, also add:
        # graph[v].append(u)

    # Step 2: Visited + queue
    visited = [False] * n
    queue = deque([start])

    visited[start] = True
    result = []

    # Step 3: BFS traversal
    while queue:
        node = queue.popleft()
        result.append(node)

        for neighbor in graph[node]:
            if not visited[neighbor]:
                visited[neighbor] = True
                queue.append(neighbor)

    return result

if __name__ == "__main__":
    n = 5
    edges = [
        (0, 1),
        (0, 2),
        (1, 3),
        (1, 4)
    ]
    
    print(bfs(n, edges, 0))
