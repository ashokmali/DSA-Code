class DSU:
    def __init__(self, n):
        """
        n : number of nodes (0 to n-1)
        """
        self.parent = list(range(n))
        self.rank = [0] * n   # can also use size instead

    def find(self, x):
        """
        Find the representative (root) of x
        Path Compression applied
        """
        if self.parent[x] != x:
            self.parent[x] = self.find(self.parent[x])
        return self.parent[x]

    def union(self, x, y):
        """
        Union two sets
        Returns True if union happened
        Returns False if already in same set
        """
        px = self.find(x)
        py = self.find(y)

        if px == py:
            return False  # already connected

        # Union by rank
        if self.rank[px] < self.rank[py]:
            self.parent[px] = py
        elif self.rank[px] > self.rank[py]:
            self.parent[py] = px
        else:
            self.parent[py] = px
            self.rank[px] += 1

        return True

if __name__ == "__main__":
    dsu = DSU(5)

    dsu.union(0, 1)
    dsu.union(1, 2)
    
    print(dsu.find(2))  # same root as 0
    print(dsu.find(3))  # different component
